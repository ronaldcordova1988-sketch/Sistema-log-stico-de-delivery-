# ===== CONFIGURACIÓN DEL BACKEND =====
# Sistema de Gestión Logística Delivery

# Puerto del servidor (Render usa la variable PORT automáticamente)
PORT=3000

# Clave API para endpoints protegidos (genera una clave segura aleatoria)
# Ejemplo: openssl rand -hex 32
ADMIN_API_KEY=tu_clave_secreta_super_segura_aqui_cambiame

# Firebase Service Account (JSON completo en UNA SOLA LÍNEA)
# Obtén este JSON desde Firebase Console:
# 1. Project Settings → Service Accounts
# 2. Generate New Private Key
# 3. Copia TODO el JSON y pégalo EN UNA SOLA LÍNEA
# 
# IMPORTANTE: En Render, pega el JSON completo sin saltos de línea
# Ejemplo:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"tu-proyecto",...}
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"CAMBIAME","private_key_id":"CAMBIAME","private_key":"-----BEGIN PRIVATE KEY-----\nCAMBIAME\n-----END PRIVATE KEY-----\n","client_email":"CAMBIAME@CAMBIAME.iam.gserviceaccount.com","client_id":"CAMBIAME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"CAMBIAME"}

# ===== CONFIGURACIÓN KEEP-ALIVE =====
# URL de tu backend en Render (para self-ping)
# Ejemplo: https://logistics-backend-abc123.onrender.com
BACKEND_URL=https://tu-servicio.onrender.com

# ===== ZONA HORARIA =====
# Para el Cron Job (ajustar según tu ubicación)
# Ejemplos: America/Mexico_City, America/New_York, Europe/Madrid
TZ=America/Mexico_City

# ===== NOTAS =====
# 1. NUNCA subas este archivo a Git (está en .gitignore)
# 2. En Render, configura estas variables en el Dashboard
# 3. Para generar ADMIN_API_KEY segura: openssl rand -hex 32
# 4. FIREBASE_SERVICE_ACCOUNT debe ser JSON en 1 línea
# 5. Configura cron-job.org para hacer ping a /keep-alive cada 10 min
